# ─────────────────────────────────────────────────────────────────────────────
#  Voice AI Agent — Environment Variables
#  Copy to .env and fill in your values
#
#  On AWS: find your public IP with:
#    curl -s http://169.254.169.254/latest/meta-data/public-ipv4
# ─────────────────────────────────────────────────────────────────────────────

# ── Deepgram (Speech-to-Text) ──────────────────────────────────────────────
# Get key at: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── Azure OpenAI (LLM) ────────────────────────────────────────────────────
# Find in Azure Portal → your OpenAI resource → Keys and Endpoint
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ── ElevenLabs (Text-to-Speech) ───────────────────────────────────────────
# Get key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Voice ID: 21m00Tcm4TlvDq8ikWAM = Rachel (free tier)
# Find other IDs at: https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Twilio (Phone Gateway) ────────────────────────────────────────────────
# Get from: https://console.twilio.com
# Leave blank to use /calls/simulate endpoint for testing
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── LiveKit (real-time audio) ─────────────────────────────────────────────
# IMPORTANT: Use wss:// (not ws://) so browsers can connect without
# Mixed Content blocks. Nginx proxies port 443 → LiveKit port 7880.
#
# Option A (domain):  wss://voiceai.yourdomain.com
# Option B (raw IP):  wss://3.111.37.1
#   (browser will show a cert warning — click Advanced → Proceed)
LIVEKIT_URL=wss://<YOUR-PUBLIC-IP-OR-DOMAIN>
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ── App Config ────────────────────────────────────────────────────────────
MAX_CONCURRENT_CALLS=100
WORKER_POOL_SIZE=100
LOG_LEVEL=INFO
WEBHOOK_PORT=8000
# IMPORTANT: Set this to your server's public HTTPS URL.
# Twilio must be able to reach this URL from the internet to open the
# Media Streams WebSocket. Use your EC2 public IP or domain.
# e.g. https://1.2.3.4  OR  https://yourserver.example.com
WEBHOOK_PUBLIC_URL=https://<YOUR-PUBLIC-IP-OR-DOMAIN>

# ── ChromaDB (Knowledge Base) ─────────────────────────────────────────────
CHROMA_PERSIST_DIR=/opt/voice-ai-agent/data/chromadb

# ── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin
